{# As 2 col with custom header #}
{%
  set classes = [
    dom_id ? 'js-view-dom-id-' ~ dom_id,
        'mb-12',
  ]
%}

<div{{ attributes.addClass(classes) }}>
  {{ title_prefix }}
  {{ title }}
  {{ title_suffix }}


  
 {% if header or exposed %}
    <header class="grid items-end gap-6 mb-6 xl:gap-10 lg:grid-cols-2 xl:grid-cols-4">
      {% if header %}
        <div class="xl:col-start-1">
          {{ header }}
        </div>
      {% endif %}

      {% if exposed %}
        <div class="self-end xl:col-start-2 xl:col-span-3">
          {{ exposed }}
        </div>
      {% endif %}
    </header>
  {% endif %}

  {{ attachment_before }}
  <div class="grid grid-flow-row-dense gap-6 mb-12 xl:gap-10 lg:grid-cols-2 xl:grid-cols-4 sm:grid-cols-2">
  {% if rows -%}
    {{ rows }}
  {% elseif empty -%}
    {{ empty }}
  {% endif %}
  </div>
  {{ pager }}

  {{ attachment_after }}
  {{ more }}

  {% if footer %}
    <footer>
      {{ footer }}
    </footer>
  {% endif %}

  {{ feed_icons }}
</div>
