{#
/**
Series page node template.
 */
#}
{%
  set classes = [
    'node',
    'node--type-' ~ node.bundle|clean_class,
    not node.isPublished() ? 'node--unpublished',
  ]
%}

<article{{ attributes.addClass(classes) }}>
  <div class="my-6">
   
    {#-- grid --#}
    <div
      class="container py-4 mx-auto lg:py-6 lg:px-8 xl:grid xl:gap-6 md:max-w-3xl xl:max-w-screen-xl 2xl:max-w-screen-2xl xl:grid-cols-12 2xl:grid-cols-12"
    >      
      <div
        class="order-1 xl:col-span-7 2xl:col-span-6 xl:col-start-4 md:order-2"
      >

        <div class="mb-4 sm:justify-between sm:flex">
          <div class="sm:order-2">{{ drupal_block('language_block:language_interface', wrapper=false) }}</div>

              {% set label = not node.page_label.isEmpty() ? node.page_label.value : node.type.entity.label %}
              <div class="text-sm font-medium leading-tight tracking-wider text-gray-500 uppercase text-muted">
                {{ label }}
              </div>
        </div>


        <h1 class="mb-6 text-4xl">{{ node.label }}</h1>

        {#-- standfirst --#}
        {% if node.field_standfirst.value %}
          <div
            class="mb-4 prose prose-lg border-b border-gray-300 lg:prose-xl"
          >
            {{ content.field_standfirst }}
          </div>
        {% endif %}

        {# attribution #} 

        {#-- date and categories --#}
        
          {% set show_date = node.field_hide_date.isEmpty() or node.field_hide_date.value != '1' %}
          {% set has_meta = not node.outcome.isEmpty() or not node.field_country.isEmpty() or show_date %}

          {% if has_meta %}
            <div class="flex flex-col flex-wrap justify-between pb-6 mb-4 prose border-b border-gray-300 xl:border-none sm:flex-row xl:mb-0">

              {% if not node.outcome.isEmpty() or not node.field_country.isEmpty() %}
                <div class="order-2 sm:order-1">
                  {% if not node.outcome.isEmpty() %}
                    <div>
                      <strong>{{ 'Outcome:'|t }}</strong> {{ node.outcome.entity.label }}
                    </div>
                  {% endif %}

                  {% if not node.field_country.isEmpty() %}
                    <div>
                      <strong>{{ 'Country:'|t }}</strong> {{ content.field_country.0 }}
                    </div>
                  {% endif %}
                </div>
              {% endif %}

              {% if show_date %}
                <div class="order-1 sm:order-2">
                  {{ node.getCreatedTime|date('d F Y') }}
                </div>
              {% endif %}

            </div>
          {% endif %}


      </div>

      {# / attribution #} {#-- collection --#}
      <div class="mb-6 xl:col-span-3 2xl:order-1 xl:pr-6 2xl:pr-12">
        {{ content.field_collections }}
      </div>

    </div>

    {# main content #}
    <div
      class="container mx-auto lg:px-8 xl:grid xl:gap-6 md:max-w-3xl xl:max-w-screen-xl 2xl:max-w-screen-2xl xl:grid-cols-12 2xl:grid-cols-12">
      <div
        class="order-1 xl:col-span-7 2xl:col-span-6 xl:col-start-4 2xl:col-start-4 md:order-2">
        {#-- image if field_display_image --#}

        {% if node.field_main_image.target_id %}
        <figure class="mb-6 -mx-4 sm:mx-0">
          <div class="overflow-hidden bg-gray-300 border rounded-xl">
            {{ content.field_main_image[0] }}
          </div>
          <figcaption
            class="px-4 mt-1 text-base leading-tight text-gray-500 sm:p-0">
            {{ content.field_image_caption }}
          </figcaption>
        </figure>
        {% endif %}

        {#-- body --#}
        <div class="prose md:prose-lg">
          <div {{ content_attributes.addClass('node-content') }}> 
          {{ content.body }} 
          {{ content.field_paragraphs }}
          </div>

        </div>

      </div>
    </div>

      {#-- layout paragraphs --#}
      {{ content.field_content }}

    {# <div
      class="container lg:px-8 xl:grid xl:gap-6 md:max-w-3xl xl:max-w-screen-xl 2xl:max-w-screen-2xl xl:grid-cols-12 2xl:grid-cols-12">
      <div class="border-t border-gray-300 xl:col-span-7 2xl:col-span-6 xl:col-start-4 2xl:col-start-4 md:order-2">
  
         {{ content.field_tags }} 
        <div class="flex items-center py-4">
          {% include '@iied_tw/partials/_share_links.html.twig' %}
          {% include '@iied_tw/partials/_copy_print_links.html.twig' %}
        </div>
      </div>
    </div> #}

      {% if not node.field_contact.isEmpty() %}
      <div class="container mx-auto xl:grid lg:gap-x-6 md:max-w-3xl xl:max-w-screen-xl 2xl:max-w-screen-2xl xl:grid-cols-12">
        <div class="lg:col-span-10 xl:col-span-7 2xl:col-span-6 xl:col-start-4 2xl:col-start-4">
          <div class="prose">{{ content.field_contact }}</div>
        </div> 
      </div>
      {% endif %}
      
  {% include '@iied_tw/partials/_series_navigation.html.twig' %}

   
  </div>
</article>
